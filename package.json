{
  "name": "sitescop-v6",
  "version": "6.0.0",
  "private": true,
  "description": "SiteScop V6 — Local Building & Pest Inspection Platform",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:installer": "npm run build:win",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "node scripts/ensure-chrome-for-pdf.mjs",
    "setup:pdf-browser": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.77.2",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "puppeteer": "^24.43.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.sitescop.inspections.v6",
    "productName": "SiteScop V6",
    "copyright": "Copyright © SiteScop Inspections",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "shared/report-pdf/legal",
        "to": "report-pdf/legal"
      },
      {
        "from": "build/sitescop-logo.jpg",
        "to": "sitescop-logo.jpg"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": [
        "en_US"
      ],
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SiteScop V6",
      "uninstallDisplayName": "SiteScop V6",
      "license": "build/installer-license.txt"
    }
  },
  "allowScripts": {
    "electron@36.9.5": true,
    "esbuild@0.25.12": true,
    "puppeteer@24.43.1": true
  }
}
